{
  "manifest_version": 3,
  "name": "FastHunter Downloader",
  "description": "Route browser downloads to the FastHunter desktop app for fast, segmented downloading. Capture any link with one click.",
  "version": "1.0.0",
  "permissions": ["activeTab", "contextMenus", "downloads", "nativeMessaging", "storage"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "FastHunter Downloader",
    "default_popup": "popup.html",
    "default_icon": { "16": "icons/icon-16.png", "32": "icons/icon-32.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" }
  },
  "icons": { "16": "icons/icon-16.png", "32": "icons/icon-32.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" }
}
