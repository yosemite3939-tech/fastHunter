{
    "name":  "@fasthunter/desktop",
    "version":  "1.0.0",
    "private":  true,
    "description":  "FastHunter Downloader Windows desktop application",
    "author":  "FastHunter",
    "main":  "dist/main/main/main.js",
    "scripts":  {
                    "dev":  "npm run build --workspace @fasthunter/download-engine \u0026\u0026 npm run build:main \u0026\u0026 concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 \u0026\u0026 cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
                    "build":  "npm run build:main \u0026\u0026 vite build",
                    "build:main":  "tsup src/main/main.ts src/preload/preload.ts --format cjs --out-dir dist/main --external electron --external sql.js",
                    "typecheck":  "tsc --noEmit",
                    "package:windows":  "npm run build \u0026\u0026 electron-builder --win nsis portable"
                },
    "dependencies":  {
                         "@fasthunter/download-engine":  "*",
                         "@fasthunter/shared-types":  "*",
                         "lucide-react":  "^0.468.0",
                         "react":  "^19.1.0",
                         "react-dom":  "^19.1.0",
                         "sql.js":  "^1.13.0"
                     },
    "devDependencies":  {
                            "@types/node":  "^24.0.0",
                            "@types/react":  "^19.1.0",
                            "@types/react-dom":  "^19.1.0",
                            "@vitejs/plugin-react":  "^4.5.2",
                            "concurrently":  "^9.1.2",
                            "cross-env":  "^7.0.3",
                            "electron":  "42.3.0",
                            "electron-builder":  "^26.0.12",
                            "tsup":  "^8.5.0",
                            "typescript":  "^5.8.3",
                            "vite":  "^6.3.5",
                            "wait-on":  "^8.0.3"
                        },
    "build":  {
                  "appId":  "com.fasthunter.downloader",
                  "productName":  "FastHunter Downloader",
                  "directories":  {
                                      "output":  "../../release/windows"
                                  },
                  "files":  [
                                "dist/**/*",
                                "package.json"
                            ],
                  "extraResources":  [
                                         {
                                             "from":  "../../assets/icons",
                                             "to":  "icons"
                                         },
                                         {
                                             "from":  "../../assets/native-host",
                                             "to":  "native-host"
                                         }
                                     ],
                  "win":  {
                              "icon":  "../../assets/icons/icon.ico",
                              "target":  [
                                             "nsis",
                                             "portable"
                                         ]
                          },
                  "nsis":  {
                               "oneClick":  false,
                               "createDesktopShortcut":  true,
                               "createStartMenuShortcut":  true
                           }
              }
}
