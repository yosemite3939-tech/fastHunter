{
  "name": "@fasthunter/download-engine",
  "version": "1.0.0",
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    "types": "./src/index.ts",
    "require": "./dist/index.js",
    "default": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --external sql.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fasthunter/shared-types": "*",
    "sql.js": "^1.13.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/sql.js": "^1.4.9",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
